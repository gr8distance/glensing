---
import SpaceLayout from "../layouts/SpaceLayout.astro";
import { TopPageTemplate } from "../templates/TopPageTemplate";
import { PACKAGES } from "../data/packages";

const featured = PACKAGES.filter((p) => p.desc).slice(0, 20);
---

<SpaceLayout title="Gravity Lensing" has3d hideFooter>
  <TopPageTemplate client:only="react" packages={PACKAGES} />
  {/* SEO fallback: invisible to users but indexable by crawlers */}
  <noscript>
    <main style="max-width:800px;margin:0 auto;padding:2rem;color:#ccc;">
      <h1>Gravity Lensing — Common Lisp Package Registry & Scope</h1>
      <p>Browse and discover Common Lisp packages. Currently indexing {PACKAGES.length} packages from Quicklisp.</p>
      <h2>Featured Packages</h2>
      <ul>
        {featured.map((p) => (
          <li><a href={`/packages/${p.name}`}>{p.name}</a> — {p.desc}</li>
        ))}
      </ul>
      <p><a href="/packages">Browse all packages</a> | <a href="/docs">Documentation</a> | <a href="/about">About</a></p>
    </main>
  </noscript>
</SpaceLayout>
